# SQL Server host used by the application.
# For the Docker Compose setup in this repository, keep localhost,1433.
DB_SERVER=localhost,1433

# Database name created/used by Entity Framework migrations.
DB_NAME=PeopleHubDB

# SQL Server login.
# The Docker Compose file uses the sa user for local development.
DB_USER=sa

# Local development password.
# Keep real secrets only in .env. Do not commit .env to source control.
DB_PASSWORD=PeopleHub@2026
